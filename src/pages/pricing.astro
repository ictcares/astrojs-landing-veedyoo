---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ButtonLink from "@/components/ButtonLink.astro";
import PageHero from "@/components/PageHero.astro";
import { site } from "@/data/site";

const plans = [
  {
    name: "Starter",
    audience: "Testing the topic-to-plan workflow",
    items: ["Topic and angle planning", "Script and storyboard drafts", "Preview before render"]
  },
  {
    name: "Creator",
    audience: "Weekly faceless documentary work",
    items: ["Template-led production", "Continuity bible", "Render-ready scene planning"]
  },
  {
    name: "Studio",
    audience: "Higher-volume production",
    items: ["Longer projects", "More asset passes", "Review-ready project structure"]
  }
];
---

<BaseLayout title="Pricing coming soon" description="Veedyoo creator pricing is coming soon. Create an account to start planning faceless documentary videos in the current studio workflow." path="/pricing/">
  <main>
    <PageHero
      label="Pricing"
      title="Creator pricing is coming soon"
      description="No checkout lives on the public site yet. The plans below explain the intended shape while creators test the studio workflow through the app."
      secondaryHref="/templates/"
      secondaryLabel="View templates"
    />
    <section class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8">
      <div class="grid gap-4 lg:grid-cols-3">
        {plans.map((plan, index) => (
          <article class={`rounded-lg border bg-ink-2 p-6 ${index === 1 ? "border-coral shadow-hard-lg" : "border-[#3d3934]"}`}>
            <div class="flex items-start justify-between gap-4">
              <h2 class="font-display text-2xl font-bold">{plan.name}</h2>
              <span class="metadata rounded bg-sand px-2 py-1 text-[8.5px] text-ink">COMING SOON</span>
            </div>
            <p class="mt-3 text-sm text-paper/52">{plan.audience}</p>
            <ul class="mt-6 space-y-3">
              {plan.items.map((item) => (
                <li class="flex gap-3 text-sm leading-6 text-paper/62">
                  <span class="mt-2 h-2 w-2 flex-none rounded-full bg-cyan"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
      <div class="mt-8 panel p-6">
        <h2 class="font-display text-2xl font-bold">No checkout on this site</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-paper/58">
          The landing page stays static. Account creation and any future billing flow remain inside the Veedyoo studio at app.veedyoo.com.
        </p>
        <ButtonLink href={site.signupUrl} label="Create your first plan" class="mt-5" />
      </div>
    </section>
  </main>
</BaseLayout>
