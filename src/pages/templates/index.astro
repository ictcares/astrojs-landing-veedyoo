---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import TemplateCard from "@/components/TemplateCard.astro";
import { templates } from "@/data/templates";

const title = "Video Templates with Real Sample Films | Veedyoo";
const description =
  "Seven documentary template styles — editorial, business, faceless documentary, tech, systems, logistics, nature — each with a real sample film generated and rendered by Veedyoo.";
---

<BaseLayout title={title} description={description} path="/templates/">
  <main>
    <PageHero
      label="Templates"
      title="Pick a style. Watch what it makes."
      description="Every template shapes the voice of the script, the imagery, and the soundtrack — and each card below carries a real, unedited film produced with that style. What you watch is what you get."
      secondaryHref="/faceless-video-maker/"
      secondaryLabel="Faceless workflow"
    />
    <section class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8">
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {templates.map((template) => <TemplateCard template={template} />)}
      </div>
    </section>
  </main>
  <script is:inline>
    document.addEventListener("play", (e) => {
      if (e.target.tagName !== "VIDEO") return;
      document.querySelectorAll("video").forEach((v) => { if (v !== e.target) v.pause(); });
    }, true);
  </script>
</BaseLayout>
