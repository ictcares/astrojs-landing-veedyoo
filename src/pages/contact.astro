---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { site } from "@/data/site";
---

<BaseLayout title="Contact Veedyoo" description="Contact Veedyoo about the AI explainer and documentary video creation studio." path="/contact/">
  <main>
    <PageHero
      label="Contact"
      title="Questions about the Veedyoo creator workflow?"
      description="The public site is static, so product access happens in the app. To try the workflow, create an account and start a production plan."
      ctaLabel="Create your first plan"
      secondaryHref="/about/"
      secondaryLabel="About Veedyoo"
    />
    <section class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8">
      <div class="panel p-6">
        <h2 class="font-display text-2xl font-bold">Product access</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-paper/58">
          Use the Veedyoo app to create an account and open the studio. The landing site does not collect messages, passwords, or personal details.
        </p>
        <a href={site.signupUrl} class="mt-5 inline-flex rounded-md border border-[#3d3934] px-4 py-2.5 font-display text-sm font-bold text-paper/70 hover:border-paper hover:text-paper">
          Open the app
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
