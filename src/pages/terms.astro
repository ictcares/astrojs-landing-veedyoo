---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Terms of Use" description="Terms of use for the Veedyoo public landing site." path="/terms/">
  <main class="mx-auto w-full max-w-[900px] px-4 py-14 sm:px-6 lg:px-8">
    <p class="metadata text-[10px] text-coral">Legal</p>
    <h1 class="mt-4 font-display text-4xl font-bold">Terms of Use</h1>
    <div class="content-prose mt-8">
      <p>These terms apply to the public Veedyoo landing site. The studio app may require separate account terms as the product matures.</p>
      <h2>Public information</h2>
      <p>Content on this site describes planned and current product workflows. Pricing shown as coming soon is informational and does not create a checkout agreement.</p>
      <h2>No professional advice</h2>
      <p>Veedyoo helps creators plan video content. You are responsible for reviewing claims, sources, rights, and generated output before publishing.</p>
      <h2>Changes</h2>
      <p>These terms may be updated as the landing site and studio product add more functionality.</p>
    </div>
  </main>
</BaseLayout>
