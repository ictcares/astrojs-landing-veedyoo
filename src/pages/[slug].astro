---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ButtonLink from "@/components/ButtonLink.astro";
import ProductFrame from "@/components/ProductFrame.astro";
import { seoPages } from "@/data/seo-pages";
import { site } from "@/data/site";
import { webApplication } from "@/lib/jsonld";

export function getStaticPaths() {
  return seoPages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
---

<BaseLayout title={page.metaTitle} description={page.description} path={`/${page.slug}/`} jsonLd={webApplication()}>
  <main>
    <section class="border-b border-line">
      <div class="mx-auto grid w-full max-w-[1180px] gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8 lg:py-18">
        <div class="flex flex-col justify-center">
          <p class="metadata text-[10px] text-coral">{page.title}</p>
          <h1 class="mt-4 font-display text-4xl font-bold leading-[1] text-paper sm:text-5xl lg:text-6xl">{page.h1}</h1>
          <p class="mt-5 text-base leading-7 text-paper/58 sm:text-lg">{page.intro}</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <ButtonLink href={site.signupUrl} label="Create your account" />
            <ButtonLink href="/use-cases/" label="Explore use cases" variant="ghost" />
          </div>
        </div>
        <ProductFrame
          title="VEEDYOO STUDIO / VIDEO WORKFLOW"
          src="/screens/editor-preview.png"
          alt="Veedyoo editor showing scene list, video preview, narration, timeline, and render controls."
          width={1440}
          height={900}
          caption="Planning, preview, and export controls stay connected to the same production workflow."
          loading="eager"
        />
      </div>
    </section>
    <section class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8">
      <div class="grid gap-4 md:grid-cols-2">
        {page.sections.map((section) => (
          <article class="panel p-6">
            <h2 class="font-display text-2xl font-bold leading-tight">{section.heading}</h2>
            <p class="mt-4 text-sm leading-7 text-paper/58">{section.body}</p>
          </article>
        ))}
      </div>
      <div class="mt-8 rounded-lg border border-coral bg-coral p-6 text-ink shadow-hard">
        <h2 class="font-display text-3xl font-bold">Start with one topic and build the plan.</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-ink/72">Create an account, open the studio, and turn your first faceless video idea into a structured project.</p>
        <a href={site.signupUrl} class="mt-5 inline-flex rounded-md border-2 border-ink bg-sand px-5 py-3 font-display text-sm font-bold text-ink shadow-hard">Create account</a>
      </div>
    </section>
  </main>
</BaseLayout>
