---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ButtonLink from "@/components/ButtonLink.astro";
import PageHero from "@/components/PageHero.astro";
import { site, absoluteUrl } from "@/data/site";

const useCases = [
  ["History documentaries", "Turn a shipwreck, an empire, or a forgotten invention into a narrated film with archival-style imagery, maps, and timelines. The classic faceless-channel format — produced in an afternoon.", "/documentary-video-maker/"],
  ["True crime & mysteries", "Unsolved cases, disappearances, and heists get the register they deserve: tense narration, evidence timelines, and moody visuals — without a single stock-footage subscription.", "/documentary-video-maker/"],
  ["Business & tech breakdowns", "How Nokia fell. Why a ship froze world trade. Explain companies, markets, and technology with data scenes, charts, and timelines that render straight from the script.", "/faceless-video-maker/"],
  ["Space, science & nature", "3D globes, telemetry HUDs, and whiteboard sketches make complex ideas visual. The narration drives the pacing, so dense topics stay watchable.", "/documentary-video-maker/"],
  ["Educational channels", "Structure a lesson as chapters with word-synced captions and on-screen emphasis. Re-voice a single line when the curriculum changes instead of re-editing a whole video.", "/youtube-script-generator/"],
  ["Rapid channel testing", "Test five topics for about a dollar each before committing to a niche. Full videos, not mockups — publish the winners, archive the rest.", "/storyboard-generator/"]
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Veedyoo use cases",
  itemListElement: useCases.map(([title, body], i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: { "@type": "CreativeWork", name: title, description: body, url: absoluteUrl("/use-cases/") }
  }))
};
---

<BaseLayout title="Use Cases — Faceless & Documentary AI Videos" description="What creators make with Veedyoo: history documentaries, true crime, business breakdowns, science explainers, educational channels — finished faceless videos from a topic." path="/use-cases/" jsonLd={jsonLd}>
  <main>
    <PageHero
      label="Use cases"
      title="What creators actually make with Veedyoo"
      description="If the video needs a story — a hook, chapters, evidence, an arc — Veedyoo produces it end to end: script, narration, visuals, music, captions, and the final render."
      secondaryHref="/documentary-video-maker/"
      secondaryLabel="How it works"
    />
    <section class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8">
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {useCases.map(([title, body, href]) => (
          <article class="panel p-6 flex flex-col">
            <h2 class="font-display text-2xl font-bold leading-tight">{title}</h2>
            <p class="mt-4 flex-1 text-sm leading-7 text-paper/58">{body}</p>
            <a href={href} class="mt-5 text-sm font-semibold text-cyan underline underline-offset-4 hover:text-paper">Learn more →</a>
          </article>
        ))}
      </div>
      <div class="mt-14 rounded-lg border border-line bg-ink-2 p-8 text-center">
        <h2 class="font-display text-3xl font-bold">Your first documentary is one sentence away</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-7 text-paper/58">Sign up free, type a topic, and watch Veedyoo write, narrate, illustrate and score it. Edit anything, then render in the cloud — from $5 in pay-as-you-go credits.</p>
        <div class="mt-6 flex justify-center">
          <ButtonLink href={site.signupUrl} label="Make your first documentary →" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
