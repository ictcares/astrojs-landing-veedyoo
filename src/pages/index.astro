---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ButtonLink from "@/components/ButtonLink.astro";
import ProductFrame from "@/components/ProductFrame.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TemplateCard from "@/components/TemplateCard.astro";
import ShowcaseCarousel from "@/components/ShowcaseCarousel.astro";
import { site } from "@/data/site";
import { showcase } from "@/data/showcase";
import { webApplication, videoItemList } from "@/lib/jsonld";
import { templates } from "@/data/templates";

const title = "AI Documentary Video Maker — Topic to Finished Film";
const description =
  "Type a topic and Veedyoo makes the documentary: AI script, narration, imagery, music and captions. Edit every scene in a timeline editor, then render a faceless YouTube-ready video in the cloud. Credits from $5.";
const jsonLd = webApplication();
const videosJsonLd = videoItemList(showcase, "Documentaries made with Veedyoo");

const workflow = [
  ["01", "Type a topic", "A ship, a company, a mystery — one sentence is enough to start a documentary."],
  ["02", "AI directs it", "Script, professional narration, archival-style imagery, music and word-synced captions are generated in minutes."],
  ["03", "Edit in the timeline", "A multi-track editor with live preview: rewrite narration, regenerate visuals, layer camera overlays, split and trim scenes."],
  ["04", "Render in the cloud", "Massively parallel cloud rendering delivers the finished MP4 with subtitles in minutes, not hours."]
];

const faqs = [
  [
    "Is Veedyoo just another AI video generator?",
    "No. Veedyoo makes complete documentaries, not clips: a narrated story with 13 cinematic scene types — 3D globes, archival stills, whiteboard sketches, kinetic type, data scenes — assembled into a coherent film you can edit scene by scene."
  ],
  [
    "Can I use it for faceless YouTube documentaries?",
    "Yes. That is exactly what it is built for: faceless documentary, explainer, tech, business, history, and mystery videos with professional narration and word-synced captions."
  ],
  [
    "Can I edit the video before rendering?",
    "Yes. Every project opens in a CapCut-style timeline editor with live preview: rewrite and re-voice narration, regenerate any image, add camera overlays and lower-thirds, split scenes, swap music — then render when the cut is right."
  ],
  [
    "How much does it cost?",
    "Sign-up is free with starter credits, and top-ups start at $5 pay-what-you-want. A typical one-minute documentary costs about a dollar in credits, including the cloud render."
  ]
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([q, a]) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a }
  }))
};
---

<BaseLayout title={title} description={description} path="/" jsonLd={[jsonLd, faqJsonLd, videosJsonLd]}>
  <main>
    <section class="relative overflow-hidden border-b border-line">
      <div class="mx-auto grid w-full max-w-[1180px] gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[0.92fr_1.08fr] lg:px-8 lg:py-18">
        <div class="flex flex-col justify-center">
          <p class="metadata text-[10px] text-coral">AI EXPLAINER VIDEO STUDIO</p>
          <h1 class="mt-4 font-display text-5xl font-bold leading-[0.94] text-paper sm:text-6xl lg:text-7xl">
            Type a topic. Get a finished documentary.
          </h1>
          <p class="mt-6 max-w-xl text-base leading-7 text-paper/58 sm:text-lg">
            The AI documentary maker for faceless creators: one sentence in — a cinematic film out, with script, narration, visuals, music and captions. Fine-tune every scene in a timeline editor, then render in the cloud.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <ButtonLink href={site.signupUrl} label="Make your first documentary" />
            <ButtonLink href="/documentary-video-maker/" label="How it works" variant="ghost" />
          </div>
          <div class="mt-7 grid gap-3 sm:grid-cols-3">
            <div class="panel p-4">
              <div class="metadata text-[9px] text-paper/40">BEST FOR</div>
              <div class="mt-2 font-display text-lg font-bold text-paper">Faceless YouTube</div>
            </div>
            <div class="panel p-4">
              <div class="metadata text-[9px] text-paper/40">WORKFLOW</div>
              <div class="mt-2 font-display text-lg font-bold text-paper">Topic to video</div>
            </div>
            <div class="panel p-4">
              <div class="metadata text-[9px] text-paper/40">PRICING</div>
              <div class="mt-2 font-display text-lg font-bold text-paper">From $5</div>
            </div>
          </div>
        </div>
        <div class="min-w-0">
          <ProductFrame
            title="NEW DOCUMENTARY / TOPIC / DIRECTOR / LENGTH"
            src="/screens/wizard-production-plan.png"
            alt="Current Veedyoo new-documentary screen with topic, AI director, target length, and documentary genre controls."
            width={1440}
            height={900}
            caption="Start with a topic, choose the AI director, length, and genre, then review the plan before generating assets."
            loading="eager"
          />
        </div>
      </div>
    </section>

    <ShowcaseCarousel />

    <section class="border-b border-line bg-ink">
      <div class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8 lg:py-18">
        <SectionHeader
          label="Workflow"
          title="From one sentence to a finished film"
          description="Faceless videos fail when scenes are generated one by one. Veedyoo writes and renders the whole story as one film — and lets you direct every scene of it."
        />
        <div class="grid gap-3 md:grid-cols-4">
          {
            workflow.map(([number, heading, body]) => (
              <div class="panel p-5">
                <div class="metadata text-[10px] text-coral">{number}</div>
                <h3 class="mt-5 font-display text-xl font-bold leading-tight text-paper">{heading}</h3>
                <p class="mt-3 text-sm leading-6 text-paper/56">{body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-b border-line">
      <div class="mx-auto grid w-full max-w-[1180px] gap-8 px-4 py-14 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8 lg:py-18">
        <div>
          <SectionHeader
            label="Preview"
            title="See the video logic before you pay for final output"
            description="Inspect scene order, narration, visual direction, and pacing while the project is still cheap to change."
          />
          <div class="space-y-3">
            <div class="rounded-lg border border-[#3d3934] bg-ink-2 p-4">
              <div class="metadata text-[9px] text-cyan">CONTINUITY</div>
              <p class="mt-2 text-sm leading-6 text-paper/58">Keep tone, palette, camera language, motifs, and forbidden drift attached to the project instead of buried in one prompt.</p>
            </div>
            <div class="rounded-lg border border-[#3d3934] bg-ink-2 p-4">
              <div class="metadata text-[9px] text-sand">SCENES</div>
              <p class="mt-2 text-sm leading-6 text-paper/58">Review every scene as narration, visual intent, timing, and asset direction instead of loose paragraphs.</p>
            </div>
          </div>
        </div>
        <ProductFrame
          title="VOYAGER 1 / EDITOR / TIMELINE"
          src="/screens/editor-preview.png"
          alt="Current Veedyoo editor showing the Voyager 1 scene list, Jupiter preview, narration inspector, and multi-track timeline."
          width={1440}
          height={900}
          caption="The real editor keeps scenes, narration, generated media, live preview, overlays, and render controls in one production surface."
        />
      </div>
    </section>

    <section class="border-b border-line bg-ink">
      <div class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8 lg:py-18">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <SectionHeader
            label="Templates"
            title="Start with a style that already knows the job"
            description="Each template gives the project a starting language for pacing, visual motifs, scene types, and the kind of evidence the video should use."
          />
          <ButtonLink href="/templates/" label="Explore all templates" variant="ghost" class="mb-8 w-full sm:w-auto" />
        </div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {templates.slice(0, 6).map((template) => <TemplateCard template={template} />)}
        </div>
      </div>
    </section>

    <section class="border-b border-line">
      <div class="mx-auto grid w-full max-w-[1180px] gap-8 px-4 py-14 sm:px-6 lg:grid-cols-[1fr_0.9fr] lg:px-8 lg:py-18">
        <div>
          <SectionHeader
            label="Pricing"
            title="Pay as you go — credits from $5"
            description="No subscription. Free starter credits at sign-up, then top up any amount from $5 — a typical one-minute documentary costs about a dollar, cloud render included."
          />
          <div class="grid gap-3 sm:grid-cols-3">
            {["Starter", "Creator", "Studio"].map((plan, index) => (
              <div class={`rounded-lg border p-5 ${index === 1 ? "border-coral bg-ink-2 shadow-hard" : "border-[#3d3934] bg-ink-2"}`}>
                <div class="font-display text-xl font-bold">{plan}</div>
                <div class="metadata mt-3 text-[9px] text-sand">CREDITS</div>
                <p class="mt-4 text-sm leading-6 text-paper/54">
                  {index === 0 ? "Free starter credits: make your first short documentary on us." : index === 1 ? "Top up from $5 for weekly faceless documentaries — pay only for what you render." : "Larger top-ups for heavier production, re-renders, and review cycles."}
                </p>
              </div>
            ))}
          </div>
        </div>
        <div class="panel p-6">
          <div class="metadata text-[10px] text-cyan">WHY THIS MATTERS</div>
          <h3 class="mt-4 font-display text-2xl font-bold leading-tight">Spend after the plan is worth rendering.</h3>
          <p class="mt-4 text-sm leading-6 text-paper/58">
            You see the full film in the live preview before spending a cent on rendering. Edit narration, visuals, and pacing for free — credits are only used when you generate assets or press render.
          </p>
          <ButtonLink href={site.signupUrl} label="Start free" class="mt-6 w-full sm:w-auto" />
        </div>
      </div>
    </section>

    <section class="border-b border-line bg-ink">
      <div class="mx-auto grid w-full max-w-[1180px] gap-8 px-4 py-14 sm:px-6 lg:grid-cols-[0.82fr_1.18fr] lg:px-8 lg:py-18">
        <div class="flex flex-col justify-center">
          <SectionHeader
            label="Brand world"
            title="Built like a production system, not a prompt toy"
            description="The visual direction is intentionally dark, editorial, and tool-like: scene cards, timeline chips, continuity spines, and documentary research surfaces."
          />
          <div class="grid gap-3 sm:grid-cols-2">
            <div class="panel p-4">
              <div class="metadata text-[9px] text-coral">PROMISE</div>
              <p class="mt-3 text-sm leading-6 text-paper/58">Nothing random. Every scene has a job.</p>
            </div>
            <div class="panel p-4">
              <div class="metadata text-[9px] text-cyan">SYSTEM</div>
              <p class="mt-3 text-sm leading-6 text-paper/58">Topic, angle, continuity, scenes, preview, export.</p>
            </div>
          </div>
        </div>
        <figure class="overflow-hidden rounded-lg border border-[#3d3934] bg-ink-2 shadow-hard-lg">
          <img
            src="/brand/veedyoo-product-world.png"
            alt="Editorial product board composed from current Veedyoo screens: the Voyager editor, new-documentary form, storyboard, and finished video."
            width={1024}
            height={1536}
            loading="lazy"
            decoding="async"
            class="max-h-[760px] w-full bg-ink object-contain"
          />
          <figcaption class="border-t border-line px-4 py-3 text-sm text-paper/52">A real Veedyoo workflow: topic and direction, scene plan, timeline edit, and finished documentary.</figcaption>
        </figure>
      </div>
    </section>

    <section class="border-b border-line">
      <div class="mx-auto grid w-full max-w-[1180px] gap-8 px-4 py-14 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-18">
        <ProductFrame
          title="YOUR DOCUMENTARIES / PROJECT DASHBOARD"
          src="/screens/dashboard-projects.png"
          alt="Current Veedyoo dashboard showing completed documentary projects with thumbnails, genres, dates, and status labels."
          width={1440}
          height={900}
          caption="Completed projects stay in one workspace, ready to open, continue editing, or review after render."
        />
        <div class="flex flex-col justify-center">
          <SectionHeader
            label="Your Veedyoo workspace"
            title="Keep every documentary in one place"
            description="Your dashboard shows every project from first plan to final render. Open a documentary to review its scenes, continue editing, or return to the finished film whenever you need it."
          />
          <ButtonLink href={site.signupUrl} label="Open your projects" class="w-full sm:w-auto" />
        </div>
      </div>
    </section>

    <section class="border-b border-line">
      <div class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8 lg:py-18">
        <SectionHeader
          label="Questions"
          title="What creators usually want to know first"
          description="The page should reduce uncertainty without pretending the product is finished beyond its current phase."
        />
        <div class="grid gap-4 md:grid-cols-2">
          {
            faqs.map(([question, answer]) => (
              <article class="panel p-6">
                <h3 class="font-display text-xl font-bold leading-tight text-paper">{question}</h3>
                <p class="mt-3 text-sm leading-7 text-paper/58">{answer}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section>
      <div class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8 lg:py-18">
        <div class="rounded-lg border border-coral bg-coral p-6 text-ink shadow-hard-lg sm:p-8">
          <div class="metadata text-[10px] text-ink/70">Start the workflow</div>
          <div class="mt-3 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
            <h2 class="max-w-3xl font-display text-3xl font-bold leading-tight sm:text-4xl">Create your first faceless documentary production plan.</h2>
            <a href={site.signupUrl} class="inline-flex items-center justify-center rounded-md border-2 border-ink bg-sand px-5 py-3 font-display text-sm font-bold text-ink shadow-hard transition hover:-translate-y-0.5">
              Create your first plan
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
