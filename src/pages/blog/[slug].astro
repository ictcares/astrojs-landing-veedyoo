---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, absoluteUrl } from "@/data/site";
import { ORG } from "@/lib/jsonld";
import { BLOG_SILOS } from "@/data/blogSilos";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const knownIds = new Set(posts.map((post) => post.id));

  // Fail the build instead of silently shipping a partial related-reading cluster.
  for (const post of posts) {
    const missingRelated = post.data.related.filter((slug) => !knownIds.has(slug));
    if (missingRelated.length > 0) {
      throw new Error(`Unknown related blog slug(s) in ${post.id}: ${missingRelated.join(", ")}`);
    }
  }

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection("blog");
const articlePath = `/blog/${post.id}/`;
const articleUrl = absoluteUrl(articlePath);
const dateModified = post.data.updatedDate ?? post.data.pubDate;
const silo = BLOG_SILOS[post.data.silo];
const siloPath = `/blog/${post.data.silo}/`;
const requestedRelated = post.data.related
  .map((slug) => allPosts.find((candidate) => candidate.id === slug))
  .filter((candidate) => candidate !== undefined);
const requestedIds = new Set(requestedRelated.map((candidate) => candidate.id));
const sameSiloFallback = allPosts
  .filter((candidate) => candidate.id !== post.id && candidate.data.silo === post.data.silo && !requestedIds.has(candidate.id))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const crossSiloFallback = allPosts
  .filter((candidate) => candidate.id !== post.id && candidate.data.silo !== post.data.silo && !requestedIds.has(candidate.id))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const relatedPosts = [...requestedRelated, ...sameSiloFallback, ...crossSiloFallback].slice(0, 3);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: articleUrl,
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": articleUrl
    },
    image: post.data.image ? absoluteUrl(post.data.image) : absoluteUrl("/og-default.svg"),
    datePublished: post.data.pubDate.toISOString(),
    dateModified: dateModified.toISOString(),
    author: {
      "@type": "Organization",
      name: post.data.author,
      url: site.baseUrl
    },
    publisher: ORG,
    articleSection: silo.label,
    isPartOf: {
      "@type": "CollectionPage",
      name: silo.title,
      url: absoluteUrl(siloPath)
    },
    keywords: post.data.tags.join(", "),
    about: post.data.about.map((name) => ({ "@type": "Thing", name })),
    mentions: post.data.mentions.map((name) => ({ "@type": "Thing", name }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: absoluteUrl("/")
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Blog",
        item: absoluteUrl("/blog/")
      },
      {
        "@type": "ListItem",
        position: 3,
        name: silo.label,
        item: absoluteUrl(siloPath)
      },
      {
        "@type": "ListItem",
        position: 4,
        name: post.data.title,
        item: articleUrl
      }
    ]
  }
];
---

<BaseLayout title={post.data.title} description={post.data.description} path={articlePath} image={post.data.image} imageAlt={post.data.imageAlt} type="article" jsonLd={jsonLd}>
  <main>
    <article class="mx-auto w-full max-w-[900px] px-4 py-14 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="metadata text-[10px] text-paper/42">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="hover:text-paper">HOME</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/blog/" class="hover:text-paper">BLOG</a></li>
          <li aria-hidden="true">/</li>
          <li><a href={siloPath} class="hover:text-paper">{silo.label}</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="min-w-0 max-w-[12rem] truncate text-paper/60 sm:max-w-[28rem]" title={post.data.title}>{post.data.title}</li>
        </ol>
      </nav>
      <h1 class="mt-5 font-display text-4xl font-bold leading-tight text-paper sm:text-5xl">{post.data.title}</h1>
      <p class="mt-5 text-lg leading-8 text-paper/58">{post.data.description}</p>
      <div class="metadata mt-6 flex flex-wrap gap-2 text-[9px] text-paper/38" aria-label="Article details">
        <a href={siloPath} class="hover:text-paper">{post.data.category}</a>
        <span>/</span>
        <span>BY {post.data.author}</span>
        <span>/</span>
        <span>
          PUBLISHED <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</time>
        </span>
        {post.data.updatedDate ? (
          <>
            <span>/</span>
            <span>
              UPDATED <time datetime={post.data.updatedDate.toISOString()}>{post.data.updatedDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</time>
            </span>
          </>
        ) : null}
        <span>/</span>
        <span>{post.data.minutesRead} MIN READ</span>
      </div>

      {post.data.image ? (
        <figure class="article-cover mt-9">
          <img
            src={post.data.image}
            width="1200"
            height="630"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            alt={post.data.imageAlt ?? ""}
          />
          {post.data.imageCaption ? <figcaption>{post.data.imageCaption}</figcaption> : null}
        </figure>
      ) : null}

      {post.data.disclosure ? (
        <aside class="article-disclosure mt-8" aria-label="Editorial disclosure">
          <p class="metadata text-[9px] text-amber">EDITORIAL DISCLOSURE</p>
          <p class="mt-2 text-sm leading-6 text-paper/64">{post.data.disclosure}</p>
        </aside>
      ) : null}

      <div class="content-prose mt-10 border-t border-line pt-8">
        <Content />
      </div>

      {relatedPosts.length > 0 ? (
        <aside class="mt-12 border-t border-line pt-8" aria-labelledby="related-reading-title">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="metadata text-[9px] text-cyan">KEEP READING</p>
              <h2 id="related-reading-title" class="mt-3 font-display text-3xl font-bold text-paper">Related guides</h2>
            </div>
            <a href={siloPath} class="text-sm font-semibold text-cyan underline underline-offset-4">More in {silo.label}</a>
          </div>
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            {relatedPosts.map((relatedPost) => (
              <a
                href={`/blog/${relatedPost.id}/`}
                class="rounded-lg border border-line bg-ink-2 p-4 transition hover:-translate-y-1 hover:border-paper hover:shadow-hard"
              >
                <span class="metadata text-[8px] text-cyan">{relatedPost.data.category}</span>
                <span class="mt-2 block font-display text-base font-bold leading-snug text-paper">{relatedPost.data.title}</span>
              </a>
            ))}
          </div>
        </aside>
      ) : null}

      <div class="mt-10 rounded-lg border border-coral bg-coral p-6 text-ink shadow-hard">
        <h2 class="font-display text-3xl font-bold">{post.data.ctaTitle ?? "Turn the framework into a project."}</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-ink/72">
          {post.data.ctaDescription ?? "Open Veedyoo and turn your next faceless video idea into a structured production workflow."}
        </p>
        <a href={site.signupUrl} class="mt-5 inline-flex rounded-md border-2 border-ink bg-sand px-5 py-3 font-display text-sm font-bold text-ink shadow-hard">
          {post.data.ctaLabel ?? "Create account"}
        </a>
      </div>
    </article>
  </main>
</BaseLayout>
