---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} path={`/blog/${post.id}/`} type="article">
  <main>
    <article class="mx-auto w-full max-w-[900px] px-4 py-14 sm:px-6 lg:px-8">
      <a href="/blog/" class="metadata text-[10px] text-paper/42 hover:text-paper">BLOG</a>
      <h1 class="mt-5 font-display text-4xl font-bold leading-tight text-paper sm:text-5xl">{post.data.title}</h1>
      <p class="mt-5 text-lg leading-8 text-paper/58">{post.data.description}</p>
      <div class="metadata mt-6 flex flex-wrap gap-2 text-[9px] text-paper/38">
        <span>{post.data.category}</span>
        <span>/</span>
        <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</time>
        <span>/</span>
        <span>{post.data.minutesRead} MIN READ</span>
      </div>
      <div class="content-prose mt-10 border-t border-line pt-8">
        <Content />
      </div>
      <div class="mt-10 rounded-lg border border-coral bg-coral p-6 text-ink shadow-hard">
        <h2 class="font-display text-3xl font-bold">Turn the framework into a project.</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-ink/72">Open Veedyoo and turn your next faceless video idea into a structured production workflow.</p>
        <a href={site.signupUrl} class="mt-5 inline-flex rounded-md border-2 border-ink bg-sand px-5 py-3 font-display text-sm font-bold text-ink shadow-hard">Create account</a>
      </div>
    </article>
  </main>
</BaseLayout>
