---
interface Props {
  label: string;
  title: string;
  description?: string;
}

const { label, title, description } = Astro.props;
---

<div class="mb-8 max-w-3xl">
  <p class="metadata text-[10px] text-paper/42">{label}</p>
  <h2 class="mt-3 font-display text-3xl font-bold leading-tight text-paper sm:text-4xl">{title}</h2>
  {description ? <p class="mt-4 text-base leading-7 text-paper/56">{description}</p> : null}
</div>
