---
import { site } from "@/data/site";
import { banner } from "@/data/banner";

// Cookie-banner-style promo strip pinned to the bottom of every page.
// Fully driven by src/data/banner.ts; dismissal is remembered per-code in
// localStorage, so launching a new code re-shows the banner to everyone.
const signupWithCode = `${site.signupUrl}?code=${encodeURIComponent(banner.code)}`;
---

{banner.enabled && (
  <div
    id="invite-banner"
    class="fixed inset-x-0 bottom-0 z-50 hidden border-t border-line bg-ink-2/97 backdrop-blur"
    role="region"
    aria-label="Beta invitation"
    data-code={banner.code}
    data-status-api={banner.showCounter ? banner.statusApi : ""}
  >
    <div class="mx-auto flex w-full max-w-[1180px] flex-col items-start gap-3 px-4 py-3.5 sm:flex-row sm:items-center sm:gap-4 sm:px-6 lg:px-8">
      <p class="min-w-0 flex-1 text-sm leading-6 text-paper/75">
        <span class="metadata mr-2 text-[9px] text-coral">{banner.kicker}</span>
        Use invitation code
        <button
          type="button"
          id="invite-code"
          class="mx-1 cursor-pointer rounded-md border border-[#3d3934] bg-ink px-2 py-0.5 font-mono text-[13px] font-bold tracking-widest text-sand transition hover:border-sand"
          title="Click to copy"
        >{banner.code}</button>
        at sign-up and <Fragment set:html={banner.rewardHtml} /> — <Fragment set:html={banner.limitHtml} />.
        <span id="invite-counter" class="metadata ml-2 hidden text-[10px] text-cyan"></span>
      </p>
      <div class="flex w-full items-center gap-2 sm:w-auto">
        <a
          href={signupWithCode}
          class="hard-button inline-flex flex-1 items-center justify-center rounded-md bg-coral px-4 py-2 font-display text-sm font-bold text-ink sm:flex-none"
        >
          {banner.ctaLabel}
        </a>
        <button
          type="button"
          id="invite-dismiss"
          aria-label="Dismiss invitation banner"
          class="rounded-md border border-[#3d3934] px-2.5 py-2 text-sm text-paper/50 transition hover:border-paper hover:text-paper"
        >
          ✕
        </button>
      </div>
    </div>
  </div>
)}

<script is:inline>
  (() => {
    const el = document.getElementById("invite-banner");
    if (!el) return;
    const code = el.dataset.code;
    const KEY = "veedyoo-banner-" + code; // per-code dismissal
    if (localStorage.getItem(KEY) === "1") return;
    el.classList.remove("hidden");

    document.getElementById("invite-dismiss")?.addEventListener("click", () => {
      el.classList.add("hidden");
      localStorage.setItem(KEY, "1");
    });

    const codeBtn = document.getElementById("invite-code");
    codeBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(code);
        const prev = codeBtn.textContent;
        codeBtn.textContent = "COPIED!";
        setTimeout(() => (codeBtn.textContent = prev), 1200);
      } catch {}
    });

    // Live "X of N redeemed" counter — silent on any failure.
    const api = el.dataset.statusApi;
    if (api) {
      fetch(api + "?code=" + encodeURIComponent(code))
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          if (!d || typeof d.uses !== "number") return;
          const counter = document.getElementById("invite-counter");
          if (!counter) return;
          counter.textContent = d.active
            ? d.uses + "/" + d.maxUses + " redeemed"
            : "fully redeemed";
          counter.classList.remove("hidden");
        })
        .catch(() => {});
    }
  })();
</script>
