---
import ButtonLink from "@/components/ButtonLink.astro";
import { site } from "@/data/site";

interface Props {
  label: string;
  title: string;
  description: string;
  ctaLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  label,
  title,
  description,
  ctaLabel = "Create your first plan",
  secondaryHref,
  secondaryLabel
} = Astro.props;
---

<section class="border-b border-line">
  <div class="mx-auto w-full max-w-[1180px] px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
    <p class="metadata text-[10px] text-coral">{label}</p>
    <h1 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-[0.98] text-paper sm:text-5xl lg:text-6xl">{title}</h1>
    <p class="mt-5 max-w-2xl text-base leading-7 text-paper/58 sm:text-lg">{description}</p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <ButtonLink href={site.signupUrl} label={ctaLabel} />
      {secondaryHref && secondaryLabel ? <ButtonLink href={secondaryHref} label={secondaryLabel} variant="ghost" /> : null}
    </div>
  </div>
</section>
