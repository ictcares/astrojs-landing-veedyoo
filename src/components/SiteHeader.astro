---
import { site } from "@/data/site";
---

<header class="sticky top-0 z-50 border-b border-line bg-ink/95 backdrop-blur">
  <div class="mx-auto flex h-[58px] w-full max-w-[1180px] items-center gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex min-w-0 items-center gap-2 font-display text-[15px] font-bold text-paper" aria-label="Veedyoo homepage">
      <img src="/brand/veedyoo-logo.png" width="32" height="32" alt="Veedyoo logo" class="h-8 w-8 rounded-md object-cover shadow-hard" loading="eager" />
      <span>Veedyoo</span>
    </a>
    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        site.nav.map((item) => (
          <a href={item.href} class="rounded-md px-3 py-2 text-sm font-medium text-paper/58 transition hover:bg-ink-2 hover:text-paper">
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="flex-1"></div>
    <a href={site.appUrl} class="hidden rounded-md border border-[#3d3934] px-3 py-2 text-sm font-semibold text-paper/65 transition hover:border-paper hover:text-paper sm:inline-flex">
      Sign in
    </a>
    <a href={site.signupUrl} class="hard-button inline-flex items-center justify-center rounded-md bg-coral px-3 py-2 font-display text-sm font-bold text-ink sm:px-4">
      Create account
    </a>
  </div>
</header>
