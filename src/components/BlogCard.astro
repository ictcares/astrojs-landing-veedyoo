---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  headingLevel?: "h2" | "h3";
}

const { post, headingLevel = "h2" } = Astro.props;
const Heading = headingLevel;
---

<article class="group overflow-hidden rounded-lg border border-[#3d3934] bg-ink-2 transition hover:-translate-y-1 hover:border-paper hover:shadow-hard">
  {post.data.image ? (
    <a href={`/blog/${post.id}/`} class="block overflow-hidden" aria-label={`Read ${post.data.title}`}>
      <img
        src={post.data.image}
        width="1200"
        height="630"
        loading="lazy"
        decoding="async"
        alt={post.data.imageAlt ?? ""}
        class="aspect-[1200/630] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
      />
    </a>
  ) : null}
  <div class="p-6">
    <p class="metadata text-[9px] text-cyan">{post.data.category}</p>
    <Heading class="mt-4 font-display text-2xl font-bold leading-tight">
      <a href={`/blog/${post.id}/`} class="underline-offset-4 hover:underline">{post.data.title}</a>
    </Heading>
    <p class="mt-4 text-sm leading-6 text-paper/58">{post.data.description}</p>
    <div class="metadata mt-5 text-[9px] text-paper/38">
      <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</time>
      <span> / </span>
      <span>{post.data.minutesRead} MIN READ</span>
    </div>
  </div>
</article>
